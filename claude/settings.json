{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/run/current-system/sw/bin/claude-permission-hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/nixos/claude-notify-stop"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/etc/nixos/claude-notify-permission"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 4102444800000
  },
  "permissions": {
    "defaultMode": "plan"
  }
}
